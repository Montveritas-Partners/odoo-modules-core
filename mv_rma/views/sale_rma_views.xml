<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_rma_form" model="ir.ui.view">
        <field name="name">sale.rma.form</field>
        <field name="model">sale.rma</field>
        <field name="arch" type="xml">
            <form string="RMA">
                <header>
                    <button name="action_confirm" type="object" string="Confirm"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_credit_note" type="object" string="Create Credit Note"
                            class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_reinvoice" type="object" string="Re-Invoice"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,processed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="sale_order_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="product_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="qty" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" placeholder="Reason for the return..."/>
                    </group>
                    <group>
                        <field name="move_id" readonly="1" invisible="not move_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sale_rma_list" model="ir.ui.view">
        <field name="name">sale.rma.list</field>
        <field name="model">sale.rma</field>
        <field name="arch" type="xml">
            <list string="RMAs">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="qty"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'processed'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_sale_rma_search" model="ir.ui.view">
        <field name="name">sale.rma.search</field>
        <field name="model">sale.rma</field>
        <field name="arch" type="xml">
            <search string="RMAs">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter name="processed" string="Processed" domain="[('state', '=', 'processed')]"/>
                <separator/>
                <group>
                    <filter name="group_partner" string="Customer" domain="[]" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Status" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_sale_rma" model="ir.actions.act_window">
        <field name="name">RMAs</field>
        <field name="res_model">sale.rma</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_sale_rma_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first RMA
            </p>
            <p>
                Raise a Return Merchandise Authorization from a sale order and
                issue a credit note or re-invoice the customer.
            </p>
        </field>
    </record>

    <menuitem id="menu_sale_rma_root"
              name="RMAs"
              parent="sale.sale_menu_root"
              action="action_sale_rma"
              sequence="90"/>
</odoo>
